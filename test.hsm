// a basic fib program as an example.
// #include "syntax.hsm"

const L 102;
const n -10;

#skipto 100;
main:
    mov $A, 1; // Curr
    mov $B, 0; // Last
loop:
    ADD $A, $B, $C;
    MOV $B, $A;
    MOV $A, $C;

    #skipto 150;
    MOV $X, $A; // Export to X
    mov $1, 100; // $<id> test

    JMP loop;
how:
    HLT; // This isn't should never be reachable.