// a basic fib program as an example.
#include "consts.hsm"

const n -10

main:
    mov $A, 1; // Curr
    mov $B, 0; // Last
loop:
    ADD $A, $B, $C;
    MOV $B, $A;
    MOV $A, $A;

    ADD $A, 100, $B; // Should error.
ADD $A, 234, 100, 80; // should also error.

    #skipto 100;
    MOV $X, $A; // Export to X
    mov $1, 100; // $<id> test

    JMP loop;
std::how:
    HLT; // This isn't should never be reachable.

#skipto 0xFF;
data:
    A; B;